# Optional: L1 Arweave GraphQL for discover / profile audio.
# Defaults try arweave.net → ar-io.dev → arweave-search.goldsky.com (geo/DNS fallbacks).
# Do NOT point this at ao-search-gateway.goldsky.com — it lacks ANS-110 Type:music and Turbo tags.
# VITE_ARWEAVE_GQL_URL=https://arweave.net/graphql

# Optional (future): Portal HB query@1.0 GraphQL after copycat@1.0 mirrors arweave.net on the node.
# StreamVault uses Turbo for uploads (not bundler@1.0) and arweave.net GraphQL today.
# VITE_HB_QUERY_URL=https://hb.portalinto.com/~query@1.0/graphql

VITE_AUDIUS_BEARER_TOKEN=your_bearer_token_here
VITE_AUDIUS_APP_NAME=StreamVault
# For Log in with Audius (OAuth): get API key from https://audius.co/settings → Manage Your Apps
VITE_AUDIUS_API_KEY=
# Optional. By default redirect_uri is the current site origin (recommended for stream-vault.xyz + Vercel).
# Only set if it matches the host users open; register EVERY production URL in Audius app redirect URIs:
#   https://stream-vault.xyz
#   https://stream-vault-three.vercel.app
#   http://localhost:5173
# VITE_AUDIUS_REDIRECT_URI=
# Portal HyperBEAM (default for profiles, spawns, atomic assets). Override only when testing another node.
# VITE_AO_URL=https://hb.portalinto.com
# VITE_AO_AUTHORITY=a5ZMUKbGClAsKzB4SHDYrwkOZZHIIfpbaxrmKwUHCe8
# VITE_AO_SCHEDULER=n_XZJhUnmldNFo4dhajoPZWhBXuJk-OcQr5JQ49c4Zo
VITE_AO_MU_URL=https://hb.portalinto.com
# Legacy-scheduler profile zone writes (not Portal HB push)
# VITE_AO_LEGACY_MU_URL=https://forward.computer
VITE_AO_CU_URL=https://forward.computer
# Dev: log profile write routing + Zone-Update sends
# VITE_DEBUG_PROFILE=1
VITE_AO_GATEWAY_URL=https://arweave.net
VITE_AO_GQL_URL=https://ao-search-gateway.goldsky.com/graphql
VITE_AO_MUSIC_REGISTRY_PROCESS=
VITE_AO_LICENSE_ENGINE_PROCESS=
VITE_AO_ROYALTY_PROCESS=
